            "explained varience ratio per pc: [0.7296 0.2285 0.0367 0.0052]\n",
            "commulative explained varience  [0.7296 0.9581 0.9948 1.    ]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "loadings=pd.DataFrame(\n",
        "    pca.components_.T,\n",
        "    columns=[f\"PC{i+1}\" for i in range(x.shape[1])],\n",
        "    index=x.columns\n",
        ")\n",
        "loadings"
