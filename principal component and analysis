      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.datasets import load_iris\n",
        "\n",
        "data=load_iris()\n",
        "x=pd.DataFrame(data.data,columns=data.feature_names)\n",
        "y=data.target"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.preprocessing import StandardScaler\n",
        "scaler=StandardScaler()\n",
        "x_scaled=scaler.fit_transform(x)"
      ],
      "metadata": {
        "id": "NGJyb_rYs_aL"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#fit PCA (all component):\n",
        "from sklearn.decomposition import PCA\n",
        "pca=PCA(n_components=x.shape[1])\n",
        "principal_component_scored=pca.fit_transform(x_scaled)\n",
        "\n",
        "explained_var=pca.explained_variance_ratio_\n",
        "print(\"explained varience ratio per pc:\",np.round(explained_var,4))\n",
        "print(\"commulative explained varience \",np.round(np.cumsum(explained_var),4))\n"
      ],
      "metadata": {
